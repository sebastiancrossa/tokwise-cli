{
  "name": "tokwise",
  "version": "0.1.1",
  "description": "Local-first CLI for syncing, downloading, transcribing, searching, and analyzing saved short-form videos.",
  "type": "module",
  "author": "Sebastian Crossa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastiancrossa/tokwise-cli.git"
  },
  "homepage": "https://github.com/sebastiancrossa/tokwise-cli#readme",
  "bugs": {
    "url": "https://github.com/sebastiancrossa/tokwise-cli/issues"
  },
  "bin": {
    "tokwise": "dist/cli.js",
    "tw": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "tokwise",
    "short-form-video",
    "cli",
    "transcription",
    "local-first",
    "knowledge-base",
    "agent-tools",
    "search",
    "bm25",
    "yt-dlp",
    "whisper"
  ],
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@tobyg74/tiktok-api-dl": "^1.3.7",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
